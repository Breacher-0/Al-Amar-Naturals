<section id="about-1" class="bg-color-01 wide-60 about-section division">
    <div class="container">
        <div class="row d-flex align-items-center">
            <!-- IMAGE BLOCK -->
            <div class="col-md-5 col-lg-6">
                <div class="img-block left-column pc-10 mb-40">
                    <img class="img-fluid" src="../include/attachment/galleryimage/646b732b6e7fc3.95022109.jpg" alt="about-image">
                </div>
            </div>
            <!-- TEXT BLOCK -->
            <div class="col-md-7 col-lg-6">
                <div class="txt-block right-column pc-15 mb-40">
                    <!-- Title -->
                    <h3 class="h3-md txt-color-01">من عمق الطبيعة إلى عمق البشرة...</h3>
                    <!-- Text -->
                    <p class="txt-color-05">بدأنا رحلتنا من قلب اسطنبول عام ٢٠١٩ بالبحث عن أنقى المواد الطبيعية وأكثرها  فعالية لنضارة البشرة ونقائها من (زيوت، أعشاب، أزهار، ثمار...)، وعملنا على توظيف أعلى المعايير العلمية بلمسة من الخبرة والإتقان، لاستخلاص وتطبيق خلطات طبيعية متنوعة ناعمة ولطيفة على البشرة.
لنقدم لكم أجود وأفضل مستحضرات التجميل والعناية الشخصية، لتستمتعوا ببشرة نقية ناعمة أكثر إشراقة وحيوية..                    </p>
                    <!-- List -->
                    <ul class="txt-list txt-color-05">
                                            </ul>
                </div>
            </div> <!-- END TEXT BLOCK -->
        </div> <!-- End row -->
    </div> <!-- End container -->
</section> <!-- END ABOUT-1 -->    <!-- ABOUT-4
============================================= -->
<section id="about-4" class="bg-color-02 wide-100 about-section division">
    <div class="container">
        <!-- SECTION TITLE -->
<div class="row">
    <div class="col-lg-12">
